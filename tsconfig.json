{
 "compilerOptions": {
  "target": "esnext",
  "module": "ES2022",
  "moduleResolution": "Node",
  "rootDir": "../../../",
  "baseUrl": ".",
  "paths": {
   "github.com/octarine-public/wrapper/*": ["../other/wrapper/*"]
  },
  "noEmit": true,
  "outDir": "scripts/",
  "noUnusedLocals": true,
  "strict": true,
  "alwaysStrict": true,
  "experimentalDecorators": true,
  "forceConsistentCasingInFileNames": true,
  "lib": ["ESNext"]
 },
 "include": ["./**/*.ts", "../other/wrapper/**/*.d.ts"],
 "exclude": ["node_modules/**/*", "scripts_files/**/*"],
 "compileOnSave": true
}
