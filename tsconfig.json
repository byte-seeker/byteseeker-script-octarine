{
	"compilerOptions": {
		"target": "esnext",
		"module": "ES2022",
		"moduleResolution": "Node",
		"baseUrl": ".",
		"paths": {
			"github.com/octarine-public/wrapper/*": ["../other/wrapper/*"],
			"github.com/octarine-public/wrapper": ["../other/wrapper/index"]
		},
		"noEmit": true,
		"outDir": "scripts/",
		"noUnusedLocals": true,
		"strict": true,
		"alwaysStrict": true,
		"experimentalDecorators": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
			"ESNext"
		]
	},
	"include": [
		"./**/*.ts",
		"../other/wrapper/**/*.d.ts"
	],
	"exclude": [
		"node_modules/**/*",
		"scripts_files/**/*"
	],
	"compileOnSave": true
}
